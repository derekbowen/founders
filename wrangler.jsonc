{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "founders-click",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2026-05-10",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "a77a2937ead70a37bce5f0ba0322030f",

  // Get a free *.workers.dev URL so we have a staging URL before the
  // founders.click custom domain is wired up.
  "workers_dev": true,

  // Static asset directory produced by `vite build` for the TanStack Start
  // client bundle. The Vite Cloudflare plugin writes here.
  "assets": {
    "directory": "./dist/client",
  },

  // Surface logs in the Cloudflare dashboard. Cheap insurance.
  "observability": {
    "enabled": true,
  },

  // Non-secret env vars. Anything secret (EMAILIT_API_KEY, OPENROUTER_API_KEY,
  // SUPABASE_SERVICE_ROLE_KEY, SEND_EMAIL_HOOK_SECRET, EMAILIT_WEBHOOK_SECRET)
  // goes in via `wrangler secret put NAME` — never in this file.
  "vars": {
    "EMAILIT_SENDER_DOMAIN": "founders.click",
    "SITE_ROOT_DOMAIN": "founders.click",
  },
}
