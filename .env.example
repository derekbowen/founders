# ─── Supabase ─────────────────────────────────────────────────────────────
# Public keys (safe to ship to client). The VITE_-prefixed variants are
# bundled into the client build by Vite.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-only — never expose. Used by webhooks and edge functions.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase Auth Hooks ──────────────────────────────────────────────────
# Set in Supabase Dashboard → Authentication → Hooks → Send Email.
# Format: "v1,whsec_<base64>" — the verifier strips the prefix internally.
SEND_EMAIL_HOOK_SECRET=

# ─── Emailit ──────────────────────────────────────────────────────────────
# Create at https://emailit.com/ → Workspace Settings → API Keys.
EMAILIT_API_KEY=

# Created when you add a webhook subscription in Emailit pointing at
#   https://YOUR_DOMAIN/lovable/email/suppression
# subscribed to events: email.bounced, email.complained, email.suppressed
# Format: "whsec_..." (signed with the full string, prefix included).
EMAILIT_WEBHOOK_SECRET=

# Verified sending domain. Defaults to notify.poolrentalnearme.online.
# Switch to notify.founders.click once that domain's DNS is verified in Emailit.
EMAILIT_SENDER_DOMAIN=notify.poolrentalnearme.online
SITE_ROOT_DOMAIN=poolrentalnearme.online

# ─── AI provider ──────────────────────────────────────────────────────────
# OpenRouter is the default — same OpenAI-compatible shape, multi-model.
# Get a key at https://openrouter.ai/keys.
# Used by content generation, blog drafts, page audits, internal-link
# suggestions, host matching, etc.
OPENROUTER_API_KEY=

# ─── Sharetribe (per-customer in SaaS mode; single-tenant for now) ────────
# Each Sharetribe marketplace the customer connects gets stored in DB once
# we add multi-tenancy. For dev, set the marketplace you're working against.
# SHARETRIBE_CLIENT_ID=
# SHARETRIBE_CLIENT_SECRET=
# SHARETRIBE_MARKETPLACE_ID=
